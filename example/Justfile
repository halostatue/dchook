# dchook example/integration Justfile

webhook_secret := justfile_dir() / "webhook_secret.txt"
client_secret := if env("CI", '') != '' { justfile_dir() / "client_secret.txt" } else { webhook_secret }
app_compose := justfile_dir() / "app/docker-compose.yml"
dchook_compose := justfile_dir() / "docker-compose.yml"
dchook_notify := justfile_dir() / "dchook-notify"
export HEALTH_URL := "http://localhost:7999/health"
export DCHOOK_URL := "http://localhost:7999"

# Default recipe - show available commands
@_default:
    just --list

# Generate a new webhook secret
generate:
    #!/usr/bin/env bash

    set -eo pipefail

    rm -f {{ webhook_secret }} {{ client_secret }}

    printf "Generating new webhook secret..."

    openssl rand -hex 32 > {{ webhook_secret }}
    chmod 0400 {{ webhook_secret }}

    if [[ -n "${CI}" ]]; then
      cp {{ webhook_secret }} {{ client_secret }}
    fi

    printf "\r✓ New secret generated (permissions: 0400)\n"

# Start dchook and app
up: _build _build_image
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    docker compose -f {{ app_compose }} -p compose up -d >/dev/null 2>&1
    docker compose -f {{ dchook_compose }} up -d >/dev/null 2>&1

    echo "Waiting for dchook to be ready..."
    for i in $(seq 1 30); do
      if curl -sf "${HEALTH_URL}" >/dev/null 2>&1; then
        break
      fi

      if ((i >= 30)); then
        echo "dchook failed to start"
        docker compose -f {{ dchook_compose }} logs dchook
        exit 1
      fi

      sleep 1
    done

# Stop dchook and app
down:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    docker compose -f {{ dchook_compose }} down >/dev/null 2>&1
    docker compose -f {{ app_compose }} -p compose down >/dev/null 2>&1

# Restart dchook and app
@restart: down up

# Show service logs
logs:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    docker compose -f {{ dchook_compose }} logs dchook

# Test successful webhook
success:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    export DCHOOK_SECRET_FILE={{ client_secret }}

    # Test backwards compatibility - no subcommand defaults to deploy
    if output=$({{ dchook_notify }} -j payload.json); then
      deployment_id=$(echo "$output" | jq -r '.deployment_id')
      echo "✓ Successful dchook trigger (deployment: ${deployment_id})"
    else
      echo "𐄂 Error sending dchook trigger (exit code $?)"
      exit 1
    fi

    just logs
    just status "${deployment_id}"

# Test deployment status query
status deployment_id:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    export DCHOOK_SECRET_FILE={{ client_secret }}

    echo "Querying deployment status: {{ deployment_id }}"
    if {{ dchook_notify }} status {{ deployment_id }}; then
      echo "✓ Status query successful"
    else
      status=$?
      echo "𐄂 Status query failed (exit code ${status})"
      exit ${status}
    fi

# Test deployment list query
list:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    export DCHOOK_SECRET_FILE={{ client_secret }}

    echo "Querying deployment list..."
    if {{ dchook_notify }} list | jq .; then
      echo "✓ List query successful"
    else
      status=$?
      echo "𐄂 List query failed (exit code ${status})"
      exit ${status}
    fi

# Test multiple deployments and list (requires 5s rate limit)
multi-deploy:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    export DCHOOK_SECRET_FILE={{ client_secret }}

    echo "Triggering multiple deployments..."
    for i in {1..3}; do
      if output=$({{ dchook_notify }} -j payload.json); then
        deployment_id=$(echo "$output" | jq -r '.deployment_id')
        echo "✓ Deployment ${i}: ${deployment_id}"
      else
        echo "𐄂 Deployment ${i} failed"
        exit 1
      fi
      sleep 6  # Wait for rate limit window (5s + buffer)
    done

    echo "Querying deployment list..."
    if {{ dchook_notify }} list; then
      echo "✓ List shows multiple deployments"
    else
      echo "𐄂 List query failed"
      exit 1
    fi

# Test rate limiting (send 2 requests quickly)
rate-limited:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    export DCHOOK_SECRET_FILE={{ client_secret }}

    if output=$({{ dchook_notify }} -j deploy payload.json); then
      deployment_id=$(echo "$output" | jq -r '.deployment_id')
      echo "✓ Successful dchook trigger (deployment: ${deployment_id})"
    else
      status=$?
      echo "𐄂 Error sending dchook trigger (exit code ${status})"
      exit ${status}
    fi

    if {{ dchook_notify }} -q deploy payload.json; then
      echo "𐄂 dchook trigger was not rate limited"
      exit 1
    else
      status=$?

      if ((status == 29)); then
        echo "✓ dchook trigger was rate limited"
      else
        echo "𐄂 dchook trigger was not rate limited (exit code ${status})"
        exit ${status}
      fi
    fi

# Test failed authentication (wrong secret)
failed:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    export DCHOOK_SECRET_FILE="{{ justfile_dir() }}/bad_secret.$$.txt"

    trap 'rm -f "${DCHOOK_SECRET_FILE}"' EXIT

    echo "wrong-secret" >"${DCHOOK_SECRET_FILE}"
    chmod 600 "${DCHOOK_SECRET_FILE}"

    # Test backwards compatibility - no subcommand defaults to deploy
    if {{ dchook_notify }} -q payload.json; then
      echo "✗ dchook trigger did not fail with bad secret"
      exit 1
    else
      status=$?

      if ((status == 41)); then
        echo "✓ dchook trigger failed with unauthorized (exit code ${status})"
      else
        echo "✗ dchook trigger failed with unexpected exit code ${status} (expected 41)"
        exit ${status}
      fi
    fi

# Test ban (2 failed attempts trigger ban, 3rd gets 403)
banned:
    #!/usr/bin/env bash

    set -eo pipefail

    cd {{ justfile_dir() }}

    export DCHOOK_SECRET_FILE="{{ justfile_dir() }}/bad_secret.$$.txt"

    trap 'rm -f "${DCHOOK_SECRET_FILE}"' EXIT

    echo "wrong-secret" >"${DCHOOK_SECRET_FILE}"
    chmod 600 "${DCHOOK_SECRET_FILE}"

    echo "Sending first failed webhook..."
    if {{ dchook_notify }} -q deploy payload.json; then
      echo "✗ First request should have failed"
      exit 1
    else
      status=$?
      if ((status == 41)); then
        echo "✓ First request unauthorized (exit code ${status})"
      else
        echo "✗ First request unexpected exit code ${status} (expected 41)"
        exit 1
      fi
    fi

    echo "Sending second failed webhook (triggers ban)..."
    if {{ dchook_notify }} -q deploy payload.json; then
      echo "✗ Second request should have failed"
      exit 1
    else
      status=$?
      if ((status == 41)); then
        echo "✓ Second request unauthorized (exit code ${status})"
      else
        echo "✗ Second request unexpected exit code ${status} (expected 41)"
        exit 1
      fi
    fi

    echo "Sending third request (should be banned)..."
    if {{ dchook_notify }} -q deploy payload.json; then
      echo "✗ Third request should have been banned"
      exit 1
    else
      status=$?
      if ((status == 43)); then
        echo "✓ Third request forbidden/banned (exit code ${status})"
      else
        echo "✗ Third request unexpected exit code ${status} (expected 43)"
        exit ${status}
      fi
    fi

    echo "✓ Ban test passed (ban lasts 1 hour, restart to clear: just restart)"

# Check service health
@health:
    echo "Checking dchook health..."
    curl -s {{ HEALTH_URL }}
    echo "\nChecking web service..."
    curl -s http://localhost:8081 | head -n 5

# Clean up everything
@clean: down
    rm -f {{ dchook_notify }} {{ webhook_secret }} {{ client_secret }}
    echo "Cleaned"

@_build:
    cd {{ justfile_dir() / ".." }} && go build -o {{ dchook_notify }} ./cmd/dchook-notify 2>&1 || { echo "Build failed"; exit 1; }

@_build_image:
    cd {{ justfile_dir() }} && docker build --build-arg RATE_LIMIT_WINDOW=5s -t example-dchook:latest -f Dockerfile .. >/dev/null 2>&1 || { echo "Image build failed"; exit 1; }
